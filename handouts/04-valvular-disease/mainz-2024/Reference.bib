@Article{Ibrahim2023,
  author   = {Ibrahim, Homam and Lowenstern, Angela and Goldsweig, Andrew M. and Rao, Sunil V.},
  journal  = {Structural Heart},
  title    = {Integrating Structural Heart Disease Trainees within the Dynamics of the Heart Team: The Case for Multimodality Training},
  year     = {2023},
  pages    = {100167--100167},
  volume   = {7},
  abstract = {Structural heart disease is a rapidly evolving field. However, training in structural heart disease is still widely variable and has not been standardized. Furthermore, integration of trainees within the heart team has not been fully defined. In this review, we discuss the components and function of the heart team, the challenges of current structural heart disease models, and possible solutions and suggestions for integrating trainees within the heart team.},
  doi      = {10.1016/j.shj.2023.100167https://pmc.ncbi.nlm.nih.gov/articles/PMC10236781/pdf/main.pdf},
  keywords = {Heart team Structural heart disease training Trainee},
