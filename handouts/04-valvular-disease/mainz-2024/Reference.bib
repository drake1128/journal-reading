  author   = {Silva, Iria and Turgeon, Pierre Yves and Paradis, Jean-Michel and Beaudoin, Jonathan and O'Connor, Kim and Ternacle, Julien and Alperi, Alberto and Panagides, Vassili and Mesnier, Jules and Gravel, Caroline and Clavel, Marie-Annick and Dagenais, François and Dumont, Eric and Mohammadi, Siamak and Pibarot, Philippe and Bernier, Mathieu and Rodés-Cabau, Josep and Salaun, Erwan},
